# EVA Red Team Harness - Environment Configuration

# Backend URL (required)
EVA_ASK_URL=http://localhost:8000/api/chat

# Optional: Authentication headers as JSON
# EVA_HEADERS_JSON={"Authorization":"Bearer YOUR_TOKEN_HERE","X-API-Key":"YOUR_API_KEY"}

# Optional: Backend health endpoint
# EVA_HEALTH_URL=http://localhost:8000/health

# Optional: Evidence pack settings
# ENVIRONMENT_NAME=development
# GIT_COMMIT=local
